<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1E"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❄️ FreezeApp"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#64B5F6"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Freeze apps — appear offline instantly"
            android:textSize="13sp"
            android:textColor="#90CAF9"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Status Bar -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="Tap apps below to select which ones to freeze"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="#424242"
        android:gravity="center"/>

    <!-- Master Freeze Button -->
    <Button
        android:id="@+id/masterFreezeBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="❄️ FREEZE SELECTED APPS"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="#1565C0"
        android:layout_margin="12dp"/>

    <!-- Search Box -->
    <EditText
        android:id="@+id/searchBox"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="8dp"
        android:hint="🔍  Search apps..."
        android:textColor="#FFFFFF"
        android:textColorHint="#9E9E9E"
        android:background="@drawable/search_bg"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:textSize="14sp"/>

    <!-- App List Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="14dp"
        android:paddingBottom="4dp"
        android:text="YOUR INSTALLED APPS"
        android:textColor="#546E7A"
        android:textSize="11sp"
        android:letterSpacing="0.1"/>

    <!-- App List -->
    <ListView
        android:id="@+id/appListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1F2A3A"
        android:dividerHeight="1dp"
        android:scrollbarThumbVertical="@android:color/darker_gray"/>

</LinearLayout>
